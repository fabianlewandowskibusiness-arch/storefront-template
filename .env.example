# ── Backend API ───────────────────────────────────────────────────────────────
#
# Base URL of the ecommerce-flow backend.
# Required in all non-local environments (production, preview, staging).
#
# MUST be ORIGIN ONLY — no /api suffix. The runtime appends /api/... paths
# to this value. If the value ends with /api the template will throw on startup.
#
#   ✓  STOREFRONT_API_URL=https://api.ecommerce-flow.ai     ← correct
#   ✗  STOREFRONT_API_URL=https://api.ecommerce-flow.ai/api ← invalid, throws
#
STOREFRONT_API_URL=https://api.ecommerce-flow.ai

# ── Cache invalidation ────────────────────────────────────────────────────────
#
# Secret token shared between the backend and the storefront.
# The backend sends this in the Authorization: Bearer header (or
# x-revalidation-secret) when calling POST /api/revalidate/storefront.
# Required in production. Leave blank to disable the revalidation endpoint.
STOREFRONT_REVALIDATION_SECRET=

# ── Legacy / single-tenant mode ───────────────────────────────────────────────
#
# STORE_ID is only used in legacy single-tenant deployments where one Vercel
# project serves exactly one storefront. In that model STORE_ID holds the
# pipelineSessionId of the deployed storefront.
#
# Multi-tenant runtime uses host-based resolution instead:
#   - proxy.ts forwards the request Host as x-storefront-host
#   - loadActiveStorefrontConfig() calls GET /storefront-runtime/by-host?host=...
#   - the response includes storeId (pipelineSessionId) in the config JSON
#
# Leave blank for multi-tenant deployments or local development.
STORE_ID=
